--- Proyecto I Diseño de Sistemas Digitales--------
--------------Parte 4 bloque ALU-------------------
----Aca juntamos las tres operaciones +-* ---------
---------------------------------------------------
---Por:Samuel Gomez, Juan Chavarro, David Fonseca--
---------------------------------------------------
LIBRARY ieee;
USE ieee.std_logic_1164.ALL;

ENTITY ALU IS
    PORT(
        bin    : IN  STD_LOGIC_VECTOR(3 DOWNTO 0);
        bin2   : IN  STD_LOGIC_VECTOR(3 DOWNTO 0);
        opcode : IN  STD_LOGIC_VECTOR(1 DOWNTO 0);

        result : OUT STD_LOGIC_VECTOR(6 DOWNTO 0);
        sign   : OUT STD_LOGIC
    );
END ENTITY ALU;

ARCHITECTURE structural OF ALU IS

    SIGNAL suma_res  : STD_LOGIC_VECTOR(6 DOWNTO 0);--Estas son señales internas de cada bloque de operacion 
    SIGNAL resta_res : STD_LOGIC_VECTOR(6 DOWNTO 0);
    SIGNAL mult_res  : STD_LOGIC_VECTOR(6 DOWNTO 0);

    SIGNAL sign_resta : STD_LOGIC;

BEGIN
---------------------------------------------------

    SUMA : ENTITY work.sumador--Acá llamo al bloque del sumador ya desarrollado en el otro archivo vhdl 
        PORT MAP(
            bin    => bin,
            bin2   => bin2,
            result => suma_res
        );
---------------------------------------------------

    RESTA : ENTITY work.restador--Lo mismo que con el sumador 
        PORT MAP(
            bin    => bin,
            bin2   => bin2,
            sign   => sign_resta,
            result => resta_res
        );

---------------------------------------------------

    MULT : ENTITY work.bloquemultiply--Lo mismo que con el sumador 
        PORT MAP(
            bin    => bin,
            bin2   => bin2,
            result => mult_res
        );
---------------------------------------------------

    WITH opcode SELECT--Tenemos un opcode con la misma funcion del opcode del bin_to_sseg, este se llamará en ese codigo
        result <=
            suma_res  WHEN "00",
            resta_res WHEN "01",
            mult_res  WHEN "10",
            "0000000" WHEN OTHERS;

    ----------------------------------------------------------------
    -- signo solo aplica para resta
    ----------------------------------------------------------------
    sign <= sign_resta WHEN opcode = "01" ELSE '0';

END ARCHITECTURE structural;