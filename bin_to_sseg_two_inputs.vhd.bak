-----------------------------------------------
--- Proyecto I Diseño de Sistemas Digitales----
---------Parte 1 bin to sseg 2 inputs--------------
----Primeros dos 7 segmentos de izq a der----------
---------------------------------------------------
LIBRARY ieee;
USE ieee.std_logic_1164.all;

ENTITY bin_to_sseg_two_inputs IS
    PORT(
        bin  : IN  STD_LOGIC_VECTOR(3 DOWNTO 0);
		  bin2 : IN  STD_LOGIC_VECTOR(3 DOWNTO 0);
        sseg : OUT STD_LOGIC_VECTOR(6 DOWNTO 0);
        sseg2: OUT STD_LOGIC_VECTOR(6 DOWNTO 0)

    );
END ENTITY bin_to_sseg_two_inputs;
----------------------------------------------------
ARCHITECTURE behaviour OF bin_to_sseg_two_inputs IS
BEGIN

    WITH bin SELECT
        sseg <=
            "1000000" WHEN "0000", --Va de HEX D0 hasta HEX D6 de izquierda a derecha (para el sseg)
            "1111001" WHEN "0001", --Si esta en 0 significa que esta prendido(para el sseg)
            "0100100" WHEN "0010",
            "0110000" WHEN "0011",
            "0011001" WHEN "0100",
            "0010010" WHEN "0101",
            "0000010" WHEN "0110",
            "1111000" WHEN "0111",
            "0000000" WHEN "1000",
            "0010000" WHEN "1001",
				--Maximo valor es 9 en decimal o sea 1001
            "0110000" WHEN "1010", -- E mandara error de aca para abajo
            "0110000" WHEN "1011", -- E 
            "0110000" WHEN "1100", -- E 
            "0110000" WHEN "1101", -- E
            "0110000" WHEN "1110", -- E
            "0110000" WHEN OTHERS; -- E  E representando error
				
				sseg2 <=
            "1000000" WHEN "0000",
            "1111001" WHEN "0001",
            "0100100" WHEN "0010",
            "0110000" WHEN "0011",
            "0011001" WHEN "0100",
            "0010010" WHEN "0101",
            "0000010" WHEN "0110",
            "1111000" WHEN "0111",
            "0000000" WHEN "1000",
            "0010000" WHEN "1001",
				--Maximo valor es 9 en decimal o sea 1001
            "0110000" WHEN "1010", -- E mandara error de aca para abajo
            "0110000" WHEN "1011", -- E 
            "0110000" WHEN "1100", -- E 
            "0110000" WHEN "1101", -- E
            "0110000" WHEN "1110", -- E
            "0110000" WHEN OTHERS; -- E  E representando error

END behaviour;